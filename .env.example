# Chart Sniper — Environment Variables
# Copy this to .env and fill in your API keys

# LLM Provider API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MINIMAX_API_KEY=

# Supabase Auth (optional — app works without auth in dev mode)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Stripe Billing (optional — app works without billing)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:3000
